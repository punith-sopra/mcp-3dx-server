                "schema": {
                  "$ref": "#/components/x-definitions/error-401"
                }
              }
            }
          },
          "403": {
            "description": "CSRF Issue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/x-definitions/error-403"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/x-definitions/error-500"
                }
              }
            }
          }
        }
      }
    },
