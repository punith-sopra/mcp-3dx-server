{
  "openapi": "3.1.0",
  "info": {
    "title": "Configure Price Quote Web Services",
    "description": "This set of APIs supports the management of Configure, Price and Quote (CPQ) related objects within the 3DEXPERIENCE platform. It enables consumers to search and fetch quote information, facilitating seamless integration with sales, engineering and product configuration processes. These APIs provide access to detailed quote data and related metadata, ensuring consistency and accuracy across the CPQ lifecycle within the 3DEXPERIENCE environment.",
    "version": "1.0.0",
    "x-ds-service": [
      "cpq"
    ],
    "x-ds-copyright": "Copyright Dassault Systemes 2024"
  },
  "servers": [
    {
      "url": "{CPQ}/resources/v1/modeler/cpq",
      "variables": {
        "CPQ": {
          "default": "https://3DEXPERIENCE_CPQ",
          "description": "URL of the CPQ service"
        }
      }
    },
    {
      "url": "{APIGateway}/api/cpq/v1",
      "description": "Cloud API Gateway",
      "variables": {
        "APIGateway": {
          "default": "https://my3DEXPERIENCE-APIGateway"
        }
      }
    }
  ],
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "paths": {
    "/quotes/search": {
      "get": {
        "tags": [
          "Quotes"
        ],
        "summary": "Gets the indexed result of quotes.",
        "description": "This service uses the indexed data to search the quotes. It will search all revisions and return matching Quotes.",
        "operationId": "GET_QuoteSearch",
        "parameters": [
          {
            "name": "$searchStr",
            "in": "query",
            "description": "This parameter is used for searching based on title/name. Search requires at least 3 characters.",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$fields",
            "in": "query",
            "description": "This parameter is used for json properties returned in response. fields name separated by comma",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$top",
            "in": "query",
            "description": "This parameter is used to specify the max records to return",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$skip",
            "in": "query",
            "description": "Represents the number of items to skip from the search result.(to be used along with $top query parameter)",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "description": "Identifies the locale of the web request.",
            "required": false,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/x-definitions/quotes-search"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/x-definitions/error-400"
                }
              }
            }
          },
          "401": {
            "description": "UNAUTHORIZED. The request requires user authentication. The response MUST include a WWW-Authenticate header field containing a challenge applicable to the requested resource. The client MAY repeat the request with a suitable Authorization header field. If the request already included Authorization credentials, then the 401 response indicates that authorization has been refused for those credentials. If the 401 response contains the same challenge as the prior response, and the user agent has already attempted authentication at least once, then the user SHOULD be presented the entity that was given in the response, since that entity might include relevant diagnostic information. HTTP access authentication is explained in HTTP Authentication: Basic and Digest Access Authentication",
            "content": {
