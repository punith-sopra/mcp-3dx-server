  "components": {
    "schemas": {
      "ExperimenttemplatesResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "templateUri"
          ],
          "properties": {
            "templateUri": {
              "type": "string",
              "description": "The uri of the experiment template",
              "examples": [
                "uuid:4504bfe7-fc59-4c2a-90ea-73971332f599"
              ]
            },
            "label": {
              "type": "string",
              "description": "The label of the experiment template",
              "examples": [
                "Synthetic Chemistry"
              ]
            }
          }
        }
      },
      "Experimenttemplate": {
        "type": "object",
        "required": [
          "templateUri"
        ],
        "properties": {
          "templateUri": {
            "type": "string",
            "description": "The uri of the experiment template",
            "examples": [
              "uuid:4504bfe7-fc59-4c2a-90ea-73971332f599"
            ]
          },
          "label": {
            "type": "string",
            "description": "The label of the experiment template",
            "examples": [
              "Synthetic Chemistry"
            ]
          },
          "backgroundFields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BackgroundField"
            }
          },
          "sections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Section"
            }
          },
          "insertableSectionTemplates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InsertableSection"
            }
          }
        }
      },
      "ExperimentreportsResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string",
              "description": "The id of the experiment report",
              "examples": [
                "Report.Audit"
              ]
            },
            "label": {
              "type": "string",
              "description": "The label of the experiment report",
              "examples": [
                "Audit Report"
              ]
            },
            "description": {
              "type": "string",
              "description": "The description of the experiment report",
              "examples": [
                "Generates a report containing the audit trail for the experiment."
              ]
            }
          }
        }
      },
      "ExperimentPost": {
        "type": "object",
        "properties": {
          "owner": {
            "$ref": "#/components/schemas/Person"
          },
          "template": {
            "type": "string",
            "description": "The id of the template to use to create the experiment",
            "examples": [
              "dsinv:Template.Experiment.SyntheticChemistry"
            ]
          },
          "title": {
            "type": "string",
            "description": "The title of the experiment",
            "examples": [
              "My experiment"
            ]
          },
          "objective": {
            "type": "string",
            "description": "The objective of the experiment",
            "examples": [
              "Investigate phenomena"
            ]
          },
          "hasSecureCollection": {
            "$ref": "#/components/schemas/SecureCollection"
          },
          "backgroundFields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BackgroundField"
            }
          }
        }
      },
      "ExperimentResponse": {
        "type": "object",
        "required": [
          "id",
          "etag"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The id of the experiment",
            "examples": [
              "uuid:4504bfe7-fc59-4c2a-90ea-73971332f599"
            ]
          },
          "etag": {
            "type": "string",
            "description": "The etag of the experiment, for optimistic locking",
            "examples": [
              "e907b9b0-f379-49df-8f46-d8cd3115d353"
            ]
          },
          "title": {
            "type": "string",
            "description": "The title of the experiment",
            "examples": [
              "My experiment"
            ]
          },
          "name": {
            "type": "string",
            "description": "The auto-generated name of the experiment",
            "examples": [
              "EXP-00000012"
            ]
          },
          "objective": {
            "type": "string",
            "description": "The objective of the experiment",
            "examples": [
              "Investigate phenomena"
            ]
          },
          "owner": {
            "$ref": "#/components/schemas/Person"
          },
          "hasSecureCollection": {
            "$ref": "#/components/schemas/SecureCollection"
          },
          "backgroundFields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BackgroundField"
            }
          },
          "sections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Section"
            }
          }
        }
      },
      "ExperimentPatch": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "examples": [
              "My experiment"
            ]
          },
          "objective": {
            "type": "string",
            "examples": [
              "Investigate phenomena"
            ]
          },
          "backgroundFields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BackgroundField"
            }
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
