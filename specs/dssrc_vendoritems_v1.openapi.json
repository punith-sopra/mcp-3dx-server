          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        },
        "parameters": [
          {
            "name": "searchStr",
            "description": "Search Criteria; 2 or more characters required.",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$top",
            "description": "The number of objects to return; default 50; max 1000",
