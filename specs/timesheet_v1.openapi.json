  "components": {
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "schemas": {
      "efforts": {
        "$ref": "#/components/x-schemas/efforts"
      },
      "timesheets": {
        "$ref": "#/components/x-schemas/timesheets"
      }
    },
    "x-schemas": {
      "efforts": {
        "allOf": [
          {
            "$ref": "#/components/x-definitions/BASICS"
          },
          {
            "$ref": "#/components/x-definitions/CESTAMP"
          },
          {
            "$ref": "#/components/x-definitions/PATCH_SUB_RESOURCE_ACTION"
          },
          {
            "type": "object",
            "properties": {
              "sunday": {
                "description": "Effort accumulated for Sunday.",
                "default": "0.0",
                "type": "string"
              },
              "monday": {
                "description": "Effort accumulated for Monday.",
                "default": "0.0",
                "type": "string"
              },
              "tuesday": {
                "description": "Effort accumulated for Tuesday",
                "default": "0.0",
                "type": "string"
              },
              "wednesday": {
                "description": "Effort accumulated for Wednesday",
                "default": "0.0",
                "type": "string"
              },
              "thursday": {
                "description": "Effort accumulated for Thursday",
                "default": "0.0",
                "type": "string"
              },
              "friday": {
                "description": "Effort accumulated for Friday",
                "default": "0.0",
                "type": "string"
              },
              "saturday": {
                "description": "Effort accumulated for Saturday",
                "default": "0.0",
                "type": "string"
              },
              "totalEffort": {
                "description": "Total effort accumulated for the week.",
                "default": "0.0",
                "type": "string",
                "readOnly": true
              },
              "state": {
                "type": "string",
                "readOnly": true
              },
              "userComments": {
                "default": "",
                "type": "string"
              },
              "approverComments": {
                "default": "",
                "type": "string",
                "readOnly": true
              }
            }
          },
          {
            "type": "object",
            "properties": {
              "task": {
                "$ref": "#/components/x-schemas/task"
              },
              "project": {
                "$ref": "#/components/x-schemas/project"
              }
            }
          },
          {}
        ]
      },
      "task": {
        "allOf": [
          {
            "$ref": "#/components/x-definitions/BASICS"
          },
          {
            "$ref": "#/components/x-definitions/CESTAMP"
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "readOnly": true
              }
            }
          },
          {}
        ]
      },
      "submit": {
        "allOf": [
          {
            "$ref": "#/components/x-definitions/BASICS"
          },
          {
            "$ref": "#/components/x-definitions/CESTAMP"
          },
          {}
        ]
      },
      "timesheets": {
        "allOf": [
          {
            "$ref": "#/components/x-definitions/BASICS"
          },
          {
            "$ref": "#/components/x-definitions/CESTAMP"
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "readOnly": true
              },
              "weekEndingDate": {
                "example": "2025-04-28T17:49:00.000",
                "default": "",
                "type": "string",
                "x-ApplicableOperations": "Create (Yes), Read (Yes), Modify (No)"
              },
              "state": {
                "type": "string",
                "readOnly": true
              },
              "userComments": {
                "default": "",
                "type": "string"
              },
              "approverComments": {
                "default": "",
                "type": "string",
                "readOnly": true
              },
              "originated": {
                "format": "date-time",
                "type": "string",
                "readOnly": true
              },
              "modified": {
                "format": "date-time",
                "type": "string",
                "readOnly": true
              },
              "modifyAccess": {
                "type": "string",
                "readOnly": true
              },
              "deleteAccess": {
                "type": "string",
                "readOnly": true
              }
            }
          },
          {
            "type": "object",
            "properties": {
              "ownerInfo": {
                "$ref": "#/components/x-schemas/ownerInfo"
              },
              "efforts": {
                "type": "array",
                "items": {
                  "$ref": "#/components/x-schemas/efforts"
                }
              },
              "associatedProjects": {
