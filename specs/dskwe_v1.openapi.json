  "servers": [
    {
      "url": "{3DSpace}/resources/v1/modeler/dskwe",
      "variables": {
        "3DSpace": {
          "default": "https://my3DEXPERIENCE-3DSpace",
          "description": "URL of the 3DSpace service"
        }
      }
    },
    {
      "url": "{APIGateway}/api/dskwe/v1",
      "description": "Cloud API Gateway",
      "variables": {
        "APIGateway": {
          "default": "https://my3DEXPERIENCE-APIGateway"
        }
      }
    },
    {
      "url": "{APIGateway}/api/dskwe/v1",
      "description": "Cloud API Gateway",
      "variables": {
        "APIGateway": {
          "default": "https://my3DEXPERIENCE-APIGateway"
        }
      }
