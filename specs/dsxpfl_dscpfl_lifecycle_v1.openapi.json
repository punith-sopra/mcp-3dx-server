{
  "openapi": "3.1.0",
  "info": {
    "description": "Web services to manage 3DPortfolio objects lifecycle including Maturity, Versioning, Duplication, Ownership and Sharing",
    "version": "1.0.0",
    "title": "3DPortfolio Lifecycle Web Services",
    "x-ds-service": [
      "3DPortfolio"
    ],
    "x-ds-copyright": "Copyright Dassault Systemes 2024"
  },
  "servers": [
    {
      "url": "{3DPortfolio}/3drdfpersist/resources/v1/modeler/dslc",
      "variables": {
        "3DPortfolio": {
          "default": "https://3DEXPERIENCE_3DPortfolio"
        }
      }
    },
    {
      "url": "{APIGateway}/api/dsxpfllc/v1",
      "description": "Cloud API Gateway",
      "variables": {
        "APIGateway": {
          "default": "https://my3DEXPERIENCE-APIGateway"
        }
      }
    }
  ],
  "paths": {
    "/maturity/getNextStates": {
      "post": {
        "summary": "Get next maturity states",
        "description": "Get the next possible maturity states for a list of objects.<br/>The request will be rejected if the total number of objects exceeds 100.",
        "operationId": "dslc:getNextStates",
        "tags": [
          "Maturity"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/xmlHttpRequestHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "id"
                      ],
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7",
                            "description": "The object identifier"
                          },
                          "nextStates": {
                            "description": "The next possible maturity states for the object",
                            "type": "array",
                            "items": {
                              "type": "string",
                              "example": "dslc:MaturityStateInWork"
                            }
                          },
                          "maturityState": {
                            "type": "string",
                            "example": "dslc:MaturityStatePrivate",
                            "description": "The current maturity state of the object"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          }
        }
      }
    },
    "/maturity/changeState": {
      "post": {
        "summary": "Change maturity states",
        "description": "Change maturity state for a list of objects.  You can change maturity to a state only along a single valid transition on the Maturity graph. To find the list of valid next states, use the web service getNextStates.<br/>The request will be rejected if the total number of objects exceeds 100.",
        "operationId": "dslc:changeState",
        "tags": [
          "Maturity"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/xmlHttpRequestHeader"
          },
          {
            "$ref": "#/components/parameters/securityContextHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "id",
                        "nextState"
                      ],
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7"
                        },
                        "nextState": {
                          "type": "string",
                          "example": "dslc:MaturityStateInWork"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7",
                            "description": "The object identifier"
                          },
                          "maturityState": {
                            "description": "The resulting maturity state for the object",
                            "type": "string",
                            "example": "dslc:MaturityStateInWork"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request:The format of the request is not correct.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@code": {
                      "type": "string",
                      "description": "Error code : Can be http code or custom app code.",
                      "example": "400"
                    },
                    "message": {
                      "type": "string",
                      "description": "Error message",
                      "example": "Maturity state dslc:MaturityStateInWork not allowed for object  uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/401"
          }
        }
      }
    },
    "/sharing/getSharing": {
      "post": {
        "summary": "Get sharings",
        "description": "Get sharing profiles of a list of objects.<br/>The request will be rejected if the total number of objects exceeds 100.",
        "operationId": "dslc:getSharing",
        "tags": [
          "Sharing"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/xmlHttpRequestHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "objectID"
                      ],
                      "properties": {
                        "objectID": {
                          "type": "string",
                          "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "objectID": {
                            "type": "string",
                            "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7"
                          },
                          "sharings": {
                            "type": "object",
                            "properties": {
                              "users": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "userID": {
                                      "type": "string",
                                      "example": "iam:user1"
                                    },
                                    "access": {
                                      "type": "string",
                                      "example": "dsxpfl:Responsibility.Manager"
                                    }
                                  }
                                }
                              },
                              "userGroups": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "userGroupID": {
                                      "type": "string",
                                      "example": "&lt;uuid:04fdc808-5698-4c0d-a7bc-09a9232e0c5d&gt;"
                                    },
                                    "access": {
                                      "type": "string",
                                      "example": "dsxpfl:Responsibility.Manager"
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          }
        }
      }
    },
    "/sharing/setSharing": {
      "post": {
        "summary": "Share objects",
        "description": "Share a list of objects with a limit of 1500, with a list of users or user groups.<br/>If access is \"None\", all access is revoked",
        "operationId": "dslc:setSharing",
        "tags": [
          "Sharing"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/xmlHttpRequestHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "objectID": {
                          "type": "string",
                          "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7"
                        },
                        "sharings": {
                          "type": "object",
                          "properties": {
                            "users": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "userID": {
                                    "type": "string",
                                    "example": "iam:user1"
                                  },
                                  "access": {
                                    "type": "string",
                                    "example": "dsxpfl:Responsibility.Manager"
                                  }
                                },
                                "required": [
                                  "userID",
                                  "access"
                                ]
                              }
                            },
                            "userGroups": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "userGroupID": {
                                    "type": "string",
                                    "example": "&lt;uuid:04fdc808-5698-4c0d-a7bc-09a9232e0c5d&gt;"
                                  },
                                  "access": {
                                    "type": "string",
                                    "example": "None"
                                  }
                                },
                                "required": [
                                  "userGroupID",
                                  "access"
                                ]
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "errorCode": {
                      "type": "string",
                      "example": "0"
                    },
                    "errorMessage": {
                      "type": "string",
                      "example": "Success"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "401": {
            "$ref": "#/components/responses/401"
          }
        }
      }
    },
    "/ownership/transfer": {
      "post": {
        "summary": "Transfer ownership",
        "description": "Transfer the ownership for a list of objects. Operation is limited to 1000 objects at a time.",
        "operationId": "dslc:transfer",
        "tags": [
          "Ownership"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/xmlHttpRequestHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "data"
                ],
                "properties": {
                  "owner": {
                    "type": "string",
                    "example": "user2"
                  },
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "id"
                      ],
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "uuid:04fdc808-5698-4c0d-a7bc-09a9232e0c5d"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "owner": {
                            "type": "string",
                            "example": "user2",
                            "description": "The user id of the object transferred. "
                          },
                          "id": {
                            "type": "string",
                            "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7",
                            "description": "The object identifier"
                          },
                          "Status": {
                            "description": "The status of the transfer on the object",
                            "type": "integer",
                            "example": 200
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "207": {
            "description": "Operation Partially succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "example": [
                    {
                      "owner": "user2",
                      "id": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7",
                      "Status": 200
                    },
                    {
                      "owner": "user2",
                      "id": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef8",
                      "Status": 400,
                      "ErrorReport": {
                        "errorMessage": "Insufficient rights to transfer."
                      }
                    }
                  ],
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "owner": {
                            "type": "string",
                            "example": "user2",
                            "description": "The user id of the object transferred. "
                          },
                          "id": {
                            "type": "string",
                            "example": "uuid:ce1a623b-a83c-4622-91b0-6b6872a48ef7",
                            "description": "The object identifier"
                          },
                          "Status": {
                            "description": "The status of the transfer on the object",
                            "type": "integer",
                            "example": 400
                          },
                          "ErrorReport": {
                            "type": "object",
                            "properties": {
                              "errorMessage": {
                                "type": "string",
                                "example": "Insufficient rights to transfer",
                                "description": "Error message"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          }
        }
      }
    },
