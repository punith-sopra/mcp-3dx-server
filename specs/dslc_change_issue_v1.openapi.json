{
  "openapi": "3.1.0",
  "info": {
    "title": "Issue Web Services",
    "description": "Issue Web Services",
    "summary": "APIs to manage issues (search, create, retrieve, patch, approve and reject)",
    "version": "1.4.0",
    "x-ds-copyright": "Copyright Dassault Systemes 2024"
  },
  "servers": [
    {
      "url": "{3DSpace}/resources/v1/modeler/dsiss",
      "variables": {
        "3DSpace": {
          "default": "https://3dspace.mydomain:443/3dspace",
          "description": "URL of the 3DSpace service"
        }
      }
    },
    {
      "url": "{APIGateway}/api/dsiss/v1",
      "description": "Cloud API Gateway",
      "variables": {
        "APIGateway": {
          "default": "https://my3DEXPERIENCE-APIGateway"
        }
      }
    }
  ],
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "paths": {
    "/issue": {
      "post": {
        "summary": "Creates a new Issue.",
        "description": "Creates a new Issue or subtype of Issue with elements passed in input. Elements passed in input can only be part of the core part or members. Output will be the core part with modified fields",
        "operationId": "POST_dsiss",
        "tags": [
          "Issue"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/securityContextParameters"
          },
          {
            "$ref": "#/components/parameters/CSRFParameters"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueCreateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issue successfully created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueOutput"
                }
              }
            }
          },
          "400": {
            "description": "Error occured during creation of the Issue. Invalid Json passed in input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "401": {
            "description": "Could be linked with missing security context or licensing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "403": {
            "description": "Function cannot be executed as a check failed, could be linked with an invalid CSRF token or a system condition unfulfilled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "500": {
            "description": "Generic issue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          }
        }
      }
    },
    "/issue/{id}": {
      "get": {
        "summary": "Retrieve an Issue.",
        "description": "Retrieves an Issue with the required facets. Core part is always retrieved",
        "operationId": "GET_dsiss:Issue_ID",
        "tags": [
          "Issue"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/securityContextParameters"
          },
          {
            "name": "id",
            "in": "path",
            "description": "The physicalid of the Issue you want to retrieve",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$fields",
            "in": "query",
            "description": "The parameter allowing retrieval of the Issue's additional fields. Comma separated list of fields among members, affectedItems, resolvedBy, contexts, resolution, customerAttributes",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Issue successfully retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueOutput"
                }
              }
            }
          },
          "400": {
            "description": "Error occured during retrieval of the Issue. Identifier passed in input is not an Issue or Invalid Json passed in input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "401": {
            "description": "Could be linked with missing security context or licensing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "403": {
            "description": "Function cannot be executed as a check failed, could be linked with an invalid CSRF token or a system condition unfulfilled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "500": {
            "description": "Generic issue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Modify an existing Issue.",
        "description": "Modify an existing Issue. Only the elements passed in input are modified. Output will be composed of the core part as well as the modified fields.",
        "operationId": "PATCH_dsiss:Issue_ID",
        "tags": [
          "Issue"
        ],
        "parameters": [
          {
            "name": "SecurityContext",
            "in": "header",
            "description": "Security context the logged in user is using like ctx::VPLMProjectLeader.MyCompany.Default",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ENO_CSRF_TOKEN",
            "in": "header",
            "description": "CSRF token could be obtained from a GET or from dedicated web service /resources/v1/application/CSRF",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The physicalid of the Issue you want to modify",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueModifyInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issue successfully modified.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueOutput"
                }
              }
            }
          },
          "400": {
            "description": "Identifier passed in input is not an Issue or invalid Json passed in input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "401": {
            "description": "Could be linked with missing security context or licensing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "403": {
            "description": "Function cannot be executed as a check failed, could be linked with an invalid CSRF token or a system condition unfulfilled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "413": {
            "description": "Addition and removal of members is limited to 10 per key in a single call.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "500": {
            "description": "Generic issue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          }
        }
      }
    },
    "/issue/{id}/approve": {
      "post": {
        "summary": "Approve an Issue",
        "description": "Approve an Issue",
        "operationId": "POSTApprove_dsiss:Issue_ID",
        "tags": [
          "Issue"
        ],
        "parameters": [
          {
            "name": "SecurityContext",
            "in": "header",
            "description": "Security context the logged in user is using like ctx::VPLMProjectLeader.MyCompany.Default",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ENO_CSRF_TOKEN",
            "in": "header",
            "description": "CSRF token could be obtained from a GET or from dedicated web service /resources/v1/application/CSRF",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The physicalid of the Issue you want to approve",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueApprovalRejectionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issue successfully approved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueBasicOutput"
                }
              }
            }
          },
          "400": {
            "description": "Identifier passed in input is not an Issue or invalid Json passed in input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "401": {
            "description": "Could be linked with missing security context or licensing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "403": {
            "description": "Function cannot be executed as a check failed, could be linked with an invalid CSRF token or a system condition unfulfilled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "500": {
            "description": "Generic issue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          }
        }
      }
    },
    "/issue/{id}/reject": {
      "post": {
        "summary": "Reject an Issue",
        "description": "Reject an Issue",
        "operationId": "POSTReject_dsiss:Issue_ID",
        "tags": [
          "Issue"
        ],
        "parameters": [
          {
            "name": "SecurityContext",
            "in": "header",
            "description": "Security context the logged in user is using like ctx::VPLMProjectLeader.MyCompany.Default",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ENO_CSRF_TOKEN",
            "in": "header",
            "description": "CSRF token could be obtained from a GET or from dedicated web service /resources/v1/application/CSRF",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The physicalid of the Issue you want to reject",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueApprovalRejectionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issue successfully rejected.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueBasicOutput"
                }
              }
            }
          },
          "400": {
            "description": "Identifier passed in input is not an Issue or invalid Json passed in input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "401": {
            "description": "Could be linked with missing security context or licensing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "403": {
            "description": "Function cannot be executed as a check failed, could be linked with an invalid CSRF token or a system condition unfulfilled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "500": {
            "description": "Generic issue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          }
        }
      }
    },
    "/issue/search": {
      "get": {
        "summary": "Gets a list of Issue from indexed search",
        "description": "Gets a list of Issue. By default, returns a total of up to 50 items, can be optionally increased upto 1000 items using $top query parameter.Recommendation, Use $searchStr query parameter with a minimum of two characters for better performances.",
        "operationId": "GETSearch_dsiss:Issue_Search",
        "tags": [
          "Issue"
        ],
        "parameters": [
          {
            "name": "SecurityContext",
            "in": "header",
            "description": "Security context the logged in user is using like ctx::VPLMProjectLeader.MyCompany.Default",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$searchStr",
            "in": "query",
            "description": "A search text to find one or more items.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$top",
            "in": "query",
            "description": "Represents the total number of items returned from the search, accepts a maximum value of 1000",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "$skip",
            "in": "query",
            "description": "Represents the number of items to skip (to be used along with $top query parameter)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchOutput"
                }
              }
            }
          },
          "401": {
            "description": "Could be linked with missing security context or licensing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          },
          "500": {
            "description": "Generic issue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorOutput"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "parameters": {
      "securityContextParameters": {
        "name": "SecurityContext",
        "in": "header",
        "description": "Security context the logged in user is using like ctx::RoleValue.OrganizationValue.CollaborativeSpaceValue",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "CSRFParameters": {
        "name": "ENO_CSRF_TOKEN",
        "in": "header",
        "description": "CSRF token could be obtained from a GET or from dedicated web service /resources/v1/application/CSRF",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "IssueApprovalRejectionInput": {
        "required": [
          "cestamp",
          "comment"
        ],
        "properties": {
          "cestamp": {
            "type": "string",
            "example": "F718B05686760000926EEB5BE7400900"
          },
          "comment": {
            "type": "string",
            "example": "associated comment"
          }
        }
      },
      "IssueCreateInput": {
        "required": [
          "description"
        ],
        "properties": {
          "description": {
            "type": "string",
            "example": "Description of Issue"
          },
          "type": {
            "type": "string",
            "example": "Type of Issue or its Sub type"
          },
          "title": {
            "type": "string",
            "example": "Title of Issue"
          },
          "name": {
            "type": "string",
            "default": "name generated by autonaming",
            "example": "name of Issue"
          },
          "priority": {
            "type": "string",
            "enum": [
              "Low",
              "Medium",
              "High"
            ],
            "default": "Low",
            "example": "Low"
          },
          "Estimated Start Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-21",
            "deprecated": true
          },
          "Planned Start Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-21"
          },
          "Estimated End Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-22",
            "deprecated": true
          },
          "Planned Completion Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-22"
          },
          "Due Completion Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-22"
          },
          "withApproval": {
            "type": "string",
            "enum": [
              "true",
              "false"
            ]
          },
          "members": {
            "type": "object",
            "$ref": "#/components/schemas/IssueInputElementMember"
          }
        }
      },
      "IssueModifyInput": {
        "required": [
          "cestamp"
        ],
        "properties": {
          "cestamp": {
            "type": "string",
            "example": "F718B05686760000926EEB5BE7400900"
          },
          "description": {
            "type": "string",
            "example": "Description of Issue"
          },
          "title": {
            "type": "string",
            "example": "Title of Issue"
          },
          "priority": {
            "type": "string",
            "enum": [
              "Low",
              "Medium",
              "High"
            ],
            "default": "Low",
            "example": "Low"
          },
          "Estimated Start Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-21",
            "deprecated": true
          },
          "Planned Start Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-21"
          },
          "Estimated End Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-22",
            "deprecated": true
          },
          "Planned Completion Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-22"
          },
          "Due Completion Date": {
            "type": "string",
            "format": "date",
            "example": "2017-07-22"
          },
          "Escalation Required": {
            "type": "string",
            "enum": [
              "Yes",
              "No"
            ],
            "example": "No"
          },
          "Resolution Recommendation": {
            "type": "string",
            "example": "Recommendation details for resolution"
          },
          "Action Taken": {
            "type": "string",
            "example": "Action taken regarding reported issue"
          },
          "Resolution Statement": {
            "type": "string",
            "example": "Statement made upon completion"
          },
          "dslc:IssueEnterpriseAttributes": {
            "$ref": "#/components/schemas/IssueEnterpriseAttributes"
          },
          "remove": {
            "$ref": "#/components/schemas/IssueModifyRemoveInput"
          },
          "add": {
            "$ref": "#/components/schemas/IssueModifyAddInput"
          },
          "replace": {
            "$ref": "#/components/schemas/IssueModifyReplaceInput"
          }
        }
      },
      "IssueEnterpriseAttributes": {
        "properties": {
          "attribute1Name": {
            "type": "string",
            "example": "attribute1Value"
          },
          "attribute2Name": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "attribute2Value"
            }
          }
        }
      },
      "IssueModifyRemoveInput": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/IssueModifyRemoveInputElement"
        }
      },
      "IssueModifyRemoveInputElement": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/IssueModifyInputElementMembers"
          },
          {
            "$ref": "#/components/schemas/IssueModifyRemoveInputElementAffectedItems"
          },
          {
            "$ref": "#/components/schemas/IssueModifyRemoveInputElementContexts"
          },
          {
            "$ref": "#/components/schemas/IssueModifyRemoveInputElementResolution"
          },
          {
            "$ref": "#/components/schemas/IssueModifyRemoveInputElementResolvedBy"
          },
          {
            "$ref": "#/components/schemas/IssueModifyRemoveInputElementCustomerAttributes"
          }
        ]
      },
      "IssueModifyInputElementMembers": {
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueInputElementMember"
            }
          }
        }
      },
      "IssueInputElementMember": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/IssueInputElementMemberAssignees"
          },
          {
            "$ref": "#/components/schemas/IssueInputElementMemberGroupAssignees"
          },
          {
            "$ref": "#/components/schemas/IssueInputElementMemberCoowners"
          },
          {
            "$ref": "#/components/schemas/IssueInputElementMemberGroupCoowners"
          },
          {
            "$ref": "#/components/schemas/IssueInputElementMemberContributors"
          },
          {
            "$ref": "#/components/schemas/IssueInputElementMemberGroupContributors"
          },
          {
            "$ref": "#/components/schemas/IssueInputElementMemberInformedUsers"
          },
          {
            "$ref": "#/components/schemas/IssueInputElementMemberGroupInformedUsers"
          }
        ]
      },
      "IssueInputElementMemberAssignees": {
        "properties": {
          "assignees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          }
        }
      },
      "IssueInputElementMemberGroupAssignees": {
        "properties": {
          "groupAssignees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Group"
            }
          }
        }
      },
      "IssueInputElementMemberCoowners": {
        "properties": {
          "coowners": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          }
        }
      },
      "IssueInputElementMemberGroupCoowners": {
        "properties": {
          "groupCoordinators": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Group"
            }
          }
        }
      },
      "IssueInputElementMemberContributors": {
        "properties": {
          "contributors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          }
        }
      },
      "IssueInputElementMemberGroupContributors": {
        "properties": {
          "groupContributors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Group"
            }
          }
        }
      },
      "IssueInputElementMemberInformedUsers": {
        "properties": {
          "informed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          }
        }
      },
      "IssueInputElementMemberGroupInformedUsers": {
        "properties": {
          "groupInformed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Group"
            }
          }
        }
      },
      "Person": {
        "type": "string",
        "example": "userX",
        "description": "full details of a Person can be retrieved using dedicated Web Service /resources/modeler/pno/person/userX"
      },
      "Group": {
        "type": "string",
        "example": "groupURI",
        "description": "full details of a Group can be retrieved using group URI"
      },
      "IssueModifyRemoveInputElementAffectedItems": {
        "properties": {
          "affectedItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AffectedItemObject"
            }
          }
        }
      },
      "IssueModifyRemoveInputElementContexts": {
        "properties": {
