{
  "openapi": "3.1.0",
  "info": {
    "title": "Change Order Web Services",
    "description": "Change Order Web Services",
    "summary": "APIs to manage change orders (create, retrieve and patch)",
    "version": "1.4.0",
    "x-ds-copyright": "Copyright Dassault Systemes 2024"
  },
  "servers": [
    {
      "url": "{3DSpace}/resources/v1/modeler/dscm",
      "variables": {
        "3DSpace": {
          "default": "https://3dspace.mydomain:443/3dspace",
          "description": "URL of the 3DSpace service"
        }
      }
    },
    {
      "url": "{APIGateway}/api/dscm:CO/v1",
      "description": "Cloud API Gateway",
      "variables": {
        "APIGateway": {
          "default": "https://my3DEXPERIENCE-APIGateway"
        }
      }
    }
  ],
  "security": [
    {
      "BasicAuth": []
    }
  ],
  "paths": {
    "/changeorder": {
      "post": {
        "summary": "Creates a new Change Order.",
        "description": "Creates a new Change Order or subtype of Change Order with elements passed in input. Elements passed in input can only be part of the core part",
        "operationId": "POST_dscm_co",
        "tags": [
          "Change Order"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/securityContextParameters"
          },
          {
            "$ref": "#/components/parameters/CSRFParameters"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/createChangeOrderRequestBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/200OKPost"
          },
          "400": {
            "$ref": "#/components/responses/400KO"
          },
          "401": {
            "$ref": "#/components/responses/401KO"
          },
          "403": {
            "$ref": "#/components/responses/403KO"
          },
          "500": {
            "$ref": "#/components/responses/500KO"
          }
        }
      }
    },
    "/changeorder/{id}": {
      "get": {
        "summary": "Retrieve a Change Order.",
        "description": "Retrieves a Change Order with the required facets. Core part is always retrieved",
        "operationId": "GET_dscm_co:co_ID",
        "tags": [
          "Change Order"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/securityContextParameters"
          },
          {
            "$ref": "#/components/parameters/coIdParameters"
          },
          {
            "$ref": "#/components/parameters/fieldsParameters"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/200OKGet"
          },
          "400": {
            "$ref": "#/components/responses/400KO"
          },
          "401": {
            "$ref": "#/components/responses/401KO"
          },
          "403": {
            "$ref": "#/components/responses/403KO"
          },
          "404": {
            "$ref": "#/components/responses/404KO"
          },
          "500": {
            "$ref": "#/components/responses/500KO"
          }
        }
      },
      "patch": {
        "summary": "Modify an existing Change Order.",
        "description": "Modify an existing Change Order. Only the elements passed in input are modified. Output will be composed of the core part as well as the modified fields.",
        "operationId": "PATCH_dscm_co:co_ID",
        "tags": [
          "Change Order"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/securityContextParameters"
          },
          {
            "$ref": "#/components/parameters/CSRFParameters"
          },
          {
            "$ref": "#/components/parameters/coIdParameters"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/modifyChangeOrderRequestBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/200OKPatch"
          },
          "400": {
            "$ref": "#/components/responses/400KO"
          },
          "401": {
            "$ref": "#/components/responses/401KO"
          },
          "403": {
            "$ref": "#/components/responses/403KO"
          },
          "404": {
            "$ref": "#/components/responses/404KO"
          },
          "500": {
            "$ref": "#/components/responses/500KO"
          }
        }
      }
    },
    "/changeorder/{id}/cancel": {
      "post": {
        "summary": "Cancel an existing Change Order.",
        "description": "Cancel a Change Order",
        "operationId": "POSTCancel_dscm_co:co_ID",
        "tags": [
          "Change Order"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/securityContextParameters"
          },
          {
            "$ref": "#/components/parameters/CSRFParameters"
          },
          {
            "$ref": "#/components/parameters/coIdParameters"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/simpleActionChangeOrderRequestBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/200OKCancel"
          },
          "400": {
            "$ref": "#/components/responses/400KO"
          },
          "401": {
            "$ref": "#/components/responses/401KO"
          },
          "403": {
            "$ref": "#/components/responses/403KO"
          },
          "404": {
            "$ref": "#/components/responses/404KO"
          },
          "500": {
            "$ref": "#/components/responses/500KO"
          }
        }
      }
    },
    "/changeorder/{id}/hold": {
      "post": {
        "summary": "Set an existing Change Order on hold.",
        "description": "Set a Change Order on hold",
        "operationId": "POSTHold_dscm_co:co_ID",
        "tags": [
          "Change Order"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/securityContextParameters"
          },
          {
            "$ref": "#/components/parameters/CSRFParameters"
          },
          {
            "$ref": "#/components/parameters/coIdParameters"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/simpleActionChangeOrderRequestBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/200OKOnHold"
          },
          "400": {
            "$ref": "#/components/responses/400KO"
          },
          "401": {
            "$ref": "#/components/responses/401KO"
          },
          "403": {
            "$ref": "#/components/responses/403KO"
          },
          "404": {
            "$ref": "#/components/responses/404KO"
          },
          "500": {
            "$ref": "#/components/responses/500KO"
          }
        }
      }
    },
    "/changeorder/{id}/resume": {
      "post": {
        "summary": "Resume an existing Change Order.",
        "description": "Resume a Change Order",
        "operationId": "POSTResume_dscm_co:co_ID",
        "tags": [
          "Change Order"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/securityContextParameters"
          },
          {
            "$ref": "#/components/parameters/CSRFParameters"
          },
          {
            "$ref": "#/components/parameters/coIdParameters"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/simpleActionChangeOrderRequestBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/200OKResume"
          },
          "400": {
            "$ref": "#/components/responses/400KO"
          },
          "401": {
            "$ref": "#/components/responses/401KO"
          },
          "403": {
            "$ref": "#/components/responses/403KO"
          },
          "404": {
            "$ref": "#/components/responses/404KO"
          },
          "500": {
            "$ref": "#/components/responses/500KO"
          }
        }
      }
    },
    "/changeorder/search": {
      "get": {
        "summary": "Gets a list of Change Orders from indexed search",
        "description": "Gets a list of Change Orders. By default, returns a total of up to 50 items, can be optionally increased upto 1000 items using $top query parameter.Recommendation, Use $searchStr query parameter with a minimum of two characters for better performances.",
        "operationId": "GETSearch_dscm_co:CO_Search",
        "tags": [
          "Change Order"
        ],
        "parameters": [
          {
            "name": "SecurityContext",
            "in": "header",
            "description": "Security context the logged in user is using like ctx::VPLMProjectLeader.MyCompany.Default",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$searchStr",
            "in": "query",
            "description": "A search text to find one or more items.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "$top",
            "in": "query",
            "description": "Represents the total number of items returned from the search, accepts a maximum value of 1000.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "$skip",
            "in": "query",
            "description": "Represents the number of items to skip (to be used along with $top query parameter)",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Could be linked with missing security context or licensing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangeOrderSearchOutPut"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/401KO"
          },
          "500": {
            "$ref": "#/components/responses/500KO"
          }
        }
      }
    }
  },
